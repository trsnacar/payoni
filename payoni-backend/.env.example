DATABASE_URL=postgresql+asyncpg://payoni:payoni_dev_pass@localhost:5432/payoni
REDIS_URL=redis://localhost:6379/0

# JWT - RS256 için private key (production'da ayrı dosya kullan)
SECRET_KEY=change-this-to-a-long-random-string

# POS credential şifreleme için 32 byte master key (base64 encoded)
PAYONI_MASTER_KEY=change-this-to-32-bytes-exactly!!

ENVIRONMENT=development
DEBUG=true

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Access token süresi (dakika)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token süresi (gün)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL (payment link yönlendirme için)
FRONTEND_URL=http://localhost:5173
